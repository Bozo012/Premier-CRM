# ============================================================
# Premier CRM — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Project URL and anon key are public (safe to expose to browser).
# Service role key is secret — server-side only, never expose to client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Project ID used by pnpm db:types when connecting to cloud project.
# Find it in: Supabase Dashboard → Project Settings → General
SUPABASE_PROJECT_ID=

# ── AI — Anthropic (required) ────────────────────────────────
# Used for all Claude calls (Haiku classification, Sonnet reasoning, Opus synthesis).
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── AI — OpenAI (required for embeddings) ────────────────────
# Used only for text-embedding-3-large to generate vault item embeddings.
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Transcription — Deepgram (required for capture pipeline) ─
# Used to transcribe audio recordings. Nova-3 model with diarization.
# Get it at: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ── SMS / Voice — Twilio (required for communications) ───────
# Powers inbound/outbound SMS and future voice features.
# Get credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number in E.164 format, e.g. +18595551234
TWILIO_PHONE_NUMBER=

# ── Transactional Email — Resend (required for email) ────────
# Powers customer-facing emails: quote delivery, receipts, notifications.
# Get it at: https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address for outgoing emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=

# ── Payments — Stripe (required for invoicing) ───────────────
# Secret key for server-side Stripe API calls.
# Webhook secret for verifying Stripe webhook payloads.
# Get credentials at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Maps — Google Maps Platform (required for geocoding) ─────
# Used for property geocoding, satellite imagery, and drive-time estimates.
# Enable: Geocoding API, Maps JavaScript API, Directions API
# Get it at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# ── Material Pricing — BigBox API (Phase 3) ──────────────────
# Used to fetch live Home Depot / Lowe's / Menards SKU prices.
# Leave blank until Phase 3 pricing engine work begins.
BIGBOX_API_KEY=

# ── Fuel Pricing — EIA API (Phase 3) ─────────────────────────
# Used for weekly fuel price feed to keep mileage cost estimates accurate.
# Free key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── App ──────────────────────────────────────────────────────
# Public URL of the app — used for magic link callbacks and absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Local AI (optional, dev only) ────────────────────────────
# Set these to use LM Studio / Qwen instead of Anthropic during development.
# Production always uses Anthropic regardless of these values.
# LOCAL_LLM_URL=http://localhost:1234/v1
# AI_PROVIDER=local
